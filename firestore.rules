rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read-only recommendation index used by the Tonight picker.
    match /tonight_index_manifest/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Public read-only dataset-backed index entries.
    match /tonight_index_entries_v1/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
