{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "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"
      }
    }
  },
  "model": "moonshotai/kimi-k2.6",
  "mcp": {
    "flutter_docs": {
      "type": "remote",
      "url": "https://mcp.flutter.dev",
      "enabled": true
    },
    "pub_dev": {
      "type": "remote",
      "url": "https://mcp.pub.dev",
      "enabled": true
    }
  },
  "agent": {
    "flutter_dev": {
      "instructions": "You are an expert Flutter developer who helps with Flutter app development. You know about widgets, state management, navigation, and best practices.",
      "tools": {
        "flutter_docs_*": true,
        "pub_dev_*": true
      }
    }
  }
}